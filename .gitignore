# ─── Large data files ─────────────────────────────────────────────────────────
# Genome assemblies & annotations (typically hundreds of MB)
# Comment out these lines if you want to track small test fixtures in git
tests/real_data/genomes/*.fna
tests/real_data/genomes/*.fasta
tests/real_data/genomes/*.fa
tests/real_data/annotations/*.gff
tests/real_data/annotations/*.gff3
tests/real_data_2/ncbi_raw/
tests/real_data_2/*.zip
tests/real_data_2/genomes/*.fna
tests/real_data_2/genomes/*.fasta
tests/real_data_2/genomes/*.fa
tests/real_data_2/annotations/*.gff
tests/real_data_2/annotations/*.gff3
mock_data/genomes/
mock_data/annotations/
data/

